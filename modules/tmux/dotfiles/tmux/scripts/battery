#!/usr/bin/env bash
bat_path=$(ls /sys/class/power_supply/BAT*/capacity 2>/dev/null | head -1)
[[ -z "$bat_path" ]] && exit 0

capacity=$(cat "$bat_path")
status=$(cat "${bat_path/capacity/status}" 2>/dev/null || echo "Unknown")

if [[ "$status" == "Charging" ]]; then
  icon="箚굜"
elif [[ "$capacity" -ge 80 ]]; then
  icon="箚겧"
elif [[ "$capacity" -ge 60 ]]; then
  icon="箚굙"
elif [[ "$capacity" -ge 40 ]]; then
  icon="箚겳"
elif [[ "$capacity" -ge 20 ]]; then
  icon="箚겱"
else
  icon="箚겫"
fi

printf "%s %s%%" "$icon" "$capacity"
